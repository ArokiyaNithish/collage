{
  "info": {
    "name": "College Workshop Management System",
    "_postman_id": "workshop-mgmt-collection-v1",
    "description": "Complete API collection for the Smart College Workshop Management System.\n\nSetup:\n1. Set environment variable `baseUrl` = http://localhost:8080\n2. After login, set `token` = value from login response\n3. Use the auto-token pre-request script on the folder level",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "workshopId", "value": "1", "type": "string" },
    { "key": "registrationId", "value": "1", "type": "string" },
    { "key": "userId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Arjun Sharma\",\n  \"email\": \"arjun@college.edu\",\n  \"password\": \"Password1\",\n  \"confirmPassword\": \"Password1\",\n  \"phone\": \"9876543210\",\n  \"department\": \"Computer Science\",\n  \"rollNumber\": \"CS22001\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register returns 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has userId', () => pm.expect(pm.response.json()).to.have.property('userId'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@college.edu\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Has token', () => pm.expect(body).to.have.property('token'));",
                  "if (body.token) { pm.collectionVariables.set('token', body.token); pm.collectionVariables.set('userId', body.userId); }",
                  "pm.test('Role is ADMIN', () => pm.expect(body.role).to.equal('ADMIN'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arjun@college.edu\",\n  \"password\": \"Password1\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.token) { pm.collectionVariables.set('token', body.token); pm.collectionVariables.set('userId', body.userId); }",
                  "pm.test('Role is STUDENT', () => pm.expect(body.role).to.equal('STUDENT'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Students (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/students", "host": ["{{baseUrl}}"], "path": ["api","auth","students"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
